<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  RewriteCond %{HTTP_HOST} ^www\.primeacademy-edu\.ru$ [NC]
  RewriteCond %{HTTPS} on
  RewriteRule ^ https://primeacademy-edu.ru%{REQUEST_URI} [R=301,L]

  RewriteCond %{HTTP_HOST} ^www\.primeacademy-edu\.ru$ [NC]
  RewriteCond %{HTTPS} !=on
  RewriteRule ^ http://primeacademy-edu.ru%{REQUEST_URI} [R=301,L]

  RewriteRule ^index\.html$ - [L]
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule . /index.html [L]
</IfModule>
